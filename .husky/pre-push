#!/usr/bin/env sh

# Detectar qué apps cambiaron comparando con origin
CHANGED_FILES=$(git diff --name-only @{push}.. 2>/dev/null || git diff --name-only origin/main..HEAD)

RUN_APP=false
RUN_LANDING=false
RUN_BACKEND=false

for file in $CHANGED_FILES; do
  case "$file" in
    apps/app/*) RUN_APP=true ;;
    apps/landing/*) RUN_LANDING=true ;;
    backend/*) RUN_BACKEND=true ;;
  esac
done

# Backend: compilar y correr los tests unitarios si hubo cambios.
# Los de integración (Testcontainers) NO van acá: necesitan Docker levantado, y bloquear el
# push de alguien que no lo tiene prendido sería peor que el problema. De esos se ocupa el CI.
if [ "$RUN_BACKEND" = true ]; then
  echo "🔨 Cambios detectados en backend/"
  echo "🚀 Compilando backend..."
  cd backend && ./gradlew compileJava --no-daemon -q
  if [ $? -ne 0 ]; then
    echo "❌ Backend no compila — push cancelado"
    exit 1
  fi
  echo "✅ Backend compila correctamente"

  echo "🧪 Tests unitarios del backend..."
  ./gradlew test --no-daemon -q
  if [ $? -ne 0 ]; then
    echo "❌ Tests del backend fallaron — push cancelado"
    exit 1
  fi
  echo "✅ Tests del backend en verde"
  cd ..
fi

if [ "$RUN_APP" = false ] && [ "$RUN_LANDING" = false ]; then
  if [ "$RUN_BACKEND" = true ]; then
    exit 0
  fi
  echo "✅ No hay cambios en apps/ ni backend/ — skip build"
  exit 0
fi

FILTER=""

if [ "$RUN_APP" = true ]; then
  FILTER="$FILTER --filter=aliados-app"
  echo "🔨 Cambios detectados en apps/app"
fi

if [ "$RUN_LANDING" = true ]; then
  FILTER="$FILTER --filter=aliados-landing"
  echo "🔨 Cambios detectados en apps/landing"
fi

echo "🚀 Corriendo build..."
pnpm turbo build $FILTER

if [ $? -ne 0 ]; then
  echo "❌ Build falló — push cancelado"
  exit 1
fi

echo "✅ Build exitoso"

# El build (tsc -b + vite build) NO corre los tests: el CI del front se cayó dos veces por
# tests rotos que este hook dejó pasar. Tardan ~3s, así que no hay excusa para no correrlos.
if [ "$RUN_APP" = true ]; then
  echo "🧪 Tests del front..."
  pnpm --filter aliados-app test
  if [ $? -ne 0 ]; then
    echo "❌ Tests del front fallaron — push cancelado"
    exit 1
  fi
  echo "✅ Tests del front en verde"
fi
