# Plantilla de variables de entorno (Vite). Copiar a `.env` y completar.
# Solo las VITE_* se exponen al frontend.

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# App
VITE_STORAGE_KEY=
VITE_API_URL=
VITE_GOOGLE_MAPS_API_KEY=

# Sentry (frontend). El DSN es público (no es secreto). Si se deja vacío, Sentry queda
# APAGADO (cero overhead) — útil en dev. Setear en el entorno de build de prod (Firebase).
VITE_SENTRY_DSN=
# Opcional: muestreo de tracing (0–1). Default 0.2 si no se setea.
VITE_SENTRY_TRACES_SAMPLE_RATE=
# Opcional: versión/release para agrupar errores por deploy.
VITE_APP_VERSION=

# ── Solo para SUBIR source maps a Sentry en el build (NO van al bundle) ──
# Estos sí son secretos → setearlos solo en el CI/entorno de build, nunca en .env commiteado.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
