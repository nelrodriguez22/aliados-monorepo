---
// Layout para páginas legales (Términos / Privacidad) de la landing.
// Self-contained: replica los tokens de tema, fuentes y chrome del index.
interface Props {
  title: string;
  subtitle?: string;
  vigencia?: string;
}
const { title, subtitle, vigencia } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} — Aliados</title>
    <script is:inline>
      // Evita el flash de tema: aplica el tema guardado antes de pintar.
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <style>
      :root {
        --brand: #054060; --brand-mid: #0a6490; --accent: #1a8abf; --green: #16a34a;
        --bg: #fafafa; --surface: #ffffff; --border: #e8e8e8; --border-strong: #d0d0d0;
        --text: #0f1117; --muted: #6b7280; --faint: #9ca3af;
      }
      html.dark {
        --brand: #1a8abf; --brand-mid: #1e9fd6; --accent: #38b6e8; --green: #4ade80;
        --bg: #0f1117; --surface: #161b27; --border: #1e2535; --border-strong: #2a3347;
        --text: #e8eaf0; --muted: #7a8499; --faint: #4a5568;
      }
      @font-face {
        font-family: 'Plus Jakarta Sans';
        src: url('/fonts/PlusJakartaSans-Variable.woff2') format('woff2');
        font-weight: 300 700; font-style: normal; font-display: swap;
      }
      @font-face {
        font-family: 'DM Sans';
        src: url('/fonts/DMSans-Variable.woff2') format('woff2');
        font-weight: 300 500; font-style: normal; font-display: swap;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0; background: var(--bg); color: var(--text);
        font-family: 'DM Sans', system-ui, sans-serif; line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      header {
        position: sticky; top: 0; z-index: 10;
        display: flex; align-items: center; justify-content: space-between;
        padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border);
        background: rgba(255,255,255,0.9); backdrop-filter: blur(12px);
      }
      html.dark header { background: rgba(15,17,23,0.92); }
      .logo { display: flex; align-items: center; text-decoration: none; }
      .logo img { height: 40px; }
      .theme-toggle {
        width: 46px; height: 26px; border-radius: 999px; border: none; cursor: pointer;
        background: var(--border-strong); position: relative; transition: background 0.2s;
      }
      html.dark .theme-toggle { background: var(--brand); }
      .toggle-thumb {
        position: absolute; top: 3px; left: 3px; width: 20px; height: 20px; border-radius: 50%;
        background: #fff; transition: transform 0.2s; display: flex; align-items: center; justify-content: center;
        font-size: 12px;
      }
      html.dark .toggle-thumb { transform: translateX(20px); }

      main { max-width: 760px; margin: 0 auto; padding: 1.5rem 1.25rem 3rem; }
      .back {
        display: inline-flex; align-items: center; gap: 0.35rem; margin-bottom: 1.25rem;
        font-size: 0.85rem; font-weight: 600; color: var(--text); text-decoration: none;
        border: 1px solid var(--border-strong); border-radius: 999px; padding: 0.4rem 0.9rem;
        transition: border-color 0.15s;
      }
      .back:hover { border-color: var(--brand); color: var(--brand); }

      h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.7rem; margin: 0 0 0.25rem; color: var(--text); }
      .subtitle { font-size: 0.9rem; color: var(--muted); margin: 0.25rem 0 0; }
      .vigencia { font-size: 0.8rem; color: var(--faint); margin: 0.2rem 0 0; }

      .content { margin-top: 1.5rem; }
      .content h2 {
        font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.05rem; font-weight: 600;
        color: var(--text); margin: 1.75rem 0 0.4rem;
      }
      .content h3 { font-size: 0.92rem; font-weight: 600; color: var(--text); margin: 1.1rem 0 0.25rem; }
      .content p { font-size: 0.9rem; color: var(--muted); margin: 0.5rem 0; }
      .content ul { margin: 0.5rem 0; padding-left: 1.3rem; }
      .content li { font-size: 0.9rem; color: var(--muted); margin: 0.3rem 0; }
      .content strong { color: var(--text); font-weight: 600; }
      .content .italic { font-style: italic; }
      .content a { color: var(--brand); text-decoration: none; }
      .content a:hover { text-decoration: underline; }

      footer { border-top: 1px solid var(--border); padding: 1.5rem 1.25rem; }
      .footer-inner {
        max-width: 760px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 0.75rem;
      }
      .footer-copy { font-size: 0.8rem; color: var(--muted); }
      .footer-links { display: flex; gap: 1.25rem; }
      .footer-links a { font-size: 0.8rem; color: var(--muted); text-decoration: none; transition: color 0.15s; }
      .footer-links a:hover { color: var(--brand); }
    </style>
  </head>

  <body>
    <header>
      <a href="/" class="logo"><img src="/logo.png" alt="Aliados" /></a>
      <button class="theme-toggle" id="themeToggle" aria-label="Cambiar tema">
        <span class="toggle-thumb"></span>
      </button>
    </header>

    <main>
      <a href="/" class="back">← Volver al inicio</a>
      <h1>{title}</h1>
      {subtitle && <p class="subtitle">{subtitle}</p>}
      {vigencia && <p class="vigencia">{vigencia}</p>}
      <div class="content">
        <slot />
      </div>
    </main>

    <footer>
      <div class="footer-inner">
        <div class="footer-copy">© 2026 Aliados. Todos los derechos reservados.</div>
        <div class="footer-links">
          <a href="mailto:aliados@convivirtech.com.ar?subject=Consulta%20desde%20Aliados">Contacto</a>
          <a href="/terminos">Términos</a>
          <a href="/privacidad">Privacidad</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const html = document.documentElement;
      document.getElementById('themeToggle')?.addEventListener('click', () => {
        html.classList.toggle('dark');
        localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
