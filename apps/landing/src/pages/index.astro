---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://aliados-app-22.web.app';
const LOGIN_URL = `${APP_URL}/login`;
const REGISTER_URL = `${APP_URL}/registro`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aliados — El profesional que necesitás, cuando lo necesitás</title>
  <meta name="description" content="Conectamos clientes con profesionales de confianza en Rosario. Electricistas, plomeros, cerrajeros y más." />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --brand:         #054060;
      --brand-mid:     #0a6490;
      --accent:        #1a8abf;
      --green:         #16a34a;
      --bg:            #fafafa;
      --surface:       #ffffff;
      --border:        #e8e8e8;
      --border-strong: #d0d0d0;
      --text:          #0f1117;
      --muted:         #6b7280;
      --faint:         #9ca3af;
    }

    html { scroll-behavior: smooth; }

    html.dark {
      --brand:         #1a8abf;
      --brand-mid:     #1e9fd6;
      --accent:        #38b6e8;
      --green:         #4ade80;
      --bg:            #0f1117;
      --surface:       #161b27;
      --border:        #1e2535;
      --border-strong: #2a3347;
      --text:          #e8eaf0;
      --muted:         #7a8499;
      --faint:         #4a5568;
    }

    @font-face {
      font-family: 'Plus Jakarta Sans';
      src: url('/fonts/PlusJakartaSans-Variable.woff2') format('woff2');
      font-weight: 300 700; font-style: normal; font-display: swap;
    }
    @font-face {
      font-family: 'DM Sans';
      src: url('/fonts/DMSans-Variable.woff2') format('woff2');
      font-weight: 300 500; font-style: normal; font-display: swap;
    }

    html.dark .services-section     { background: var(--surface); }
    html.dark .how-visual            { background: var(--surface); }
    html.dark .mock-card             { background: var(--bg); }
    html.dark .mock-map              { background: linear-gradient(135deg, #0a1929 0%, #0d2137 100%); }
    html.dark .testimonials-section  { background: var(--bg); }
    html.dark .testimonial-card      { background: var(--surface); }
    html.dark header                 { background: rgba(15,17,23,0.92); }
    html.dark .providers-section     { background: #0a1929; }
    html.dark .providers-tag         { background: rgba(26,138,191,0.15); color: var(--accent); }
    html.dark .faq-section           { background: var(--bg); }
    html.dark .final-cta             { background: var(--bg); }
    html.dark .step-preview          { background: var(--surface); }
    html.dark .prev-track            { background: linear-gradient(135deg, #0a1929, #0d2137); }

    html.dark .hero-orb-1 { background: radial-gradient(circle, rgba(26,138,191,0.30) 0%, rgba(10,100,144,0.14) 40%, transparent 70%); }
    html.dark .hero-orb-2 { background: radial-gradient(circle, rgba(56,182,232,0.22) 0%, rgba(26,138,191,0.10) 45%, transparent 70%); }
    html.dark .hero-orb-3 { background: radial-gradient(circle, rgba(26,138,191,0.18) 0%, transparent 65%); }
    html.dark .hero::before {
      background:
        radial-gradient(ellipse 80% 60% at 50% 0%, rgba(26,138,191,0.18) 0%, transparent 70%),
        linear-gradient(180deg, rgba(10,100,144,0.12) 0%, transparent 60%);
    }

    .theme-toggle {
      width: 52px; height: 28px; background: var(--border-strong);
      border-radius: 9999px; border: none; cursor: pointer;
      position: relative; transition: background 0.3s; flex-shrink: 0; padding: 0;
    }
    html.dark .theme-toggle { background: var(--brand); }
    .toggle-thumb {
      position: absolute; top: 3px; left: 3px; width: 22px; height: 22px;
      background: white; border-radius: 50%;
      transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
      display: flex; align-items: center; justify-content: center;
      color: #f59e0b; box-shadow: 0 1px 4px rgba(0,0,0,0.15);
    }
    html.dark .toggle-thumb { transform: translateX(24px); color: #94a3b8; }
    .icon-sun, .icon-moon { position: absolute; transition: opacity 0.2s; }
    .icon-sun  { opacity: 1; }
    .icon-moon { opacity: 0; }
    html.dark .icon-sun  { opacity: 0; }
    html.dark .icon-moon { opacity: 1; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg); color: var(--text);
      overflow-x: hidden; line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 60px;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 1.5rem;
      background: rgba(250,250,250,0.7);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .logo img { height: 45px; }
    .header-right { display: flex; align-items: center; gap: 1.5rem; }
    .desktop-nav { display: flex; align-items: center; gap: 1.75rem; }
    .desktop-nav a { font-size: 0.875rem; font-weight: 400; color: var(--muted); text-decoration: none; transition: color 0.2s, text-shadow 0.2s, font-weight 0.1s; }
    .desktop-nav a:hover,
    .desktop-nav a.active {
      font-weight: 500;
      color: var(--brand);
      text-shadow: 0 0 16px rgba(26,138,191,0.35), 0 0 6px rgba(26,138,191,0.2);
    }
    html.dark .desktop-nav a:hover,
    html.dark .desktop-nav a.active {
      color: var(--accent);
      text-shadow: 0 0 20px rgba(56,182,232,0.6), 0 0 8px rgba(56,182,232,0.3);
    }
    .header-btns { display: flex; align-items: center; gap: 0.5rem; }
    .btn-ghost {
      font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.875rem;
      color: var(--brand); background: none;
      border: 1px solid var(--border-strong); border-radius: 9999px;
      cursor: pointer; text-decoration: none;
      padding: 0.45rem 1rem; display: inline-block;
      transition: border-color 0.15s, color 0.15s, box-shadow 0.15s;
      white-space: nowrap;
    }
    .btn-ghost:hover {
      border-color: var(--accent);
      color: var(--accent);
      box-shadow: 0 0 10px rgba(26,138,191,0.15);
    }
    html.dark .btn-ghost { color: var(--accent); border-color: var(--border-strong); }
    html.dark .btn-ghost:hover { border-color: var(--accent); box-shadow: 0 0 12px rgba(56,182,232,0.2); }

    .hamburger { display: none; flex-direction: column; justify-content: center; align-items: center; gap: 5px; width: 36px; height: 36px; background: none; border: none; cursor: pointer; padding: 4px; border-radius: 8px; transition: background 0.15s; flex-shrink: 0; }
    .hamburger:hover { background: var(--border); }
    .hamburger span { display: block; width: 20px; height: 2px; background: var(--text); border-radius: 2px; transition: transform 0.25s ease, opacity 0.2s ease; transform-origin: center; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .mobile-menu { display: none; position: fixed; top: 60px; left: 0; right: 0; z-index: 98; background: var(--surface); border-bottom: 1px solid var(--border); padding: 1.25rem 1.25rem 1.5rem; flex-direction: column; gap: 0; box-shadow: 0 8px 24px rgba(0,0,0,0.08); animation: slideDown 0.2s ease; }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
    .mobile-menu.open { display: flex; }
    .mobile-nav { display: flex; flex-direction: column; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem; }
    .mobile-nav a { font-size: 0.9375rem; font-weight: 500; color: var(--text); padding: 0.75rem 0; border-bottom: 1px solid var(--border); text-decoration: none; transition: color 0.15s; }
    .mobile-nav a:last-child { border-bottom: none; }
    .mobile-nav a:hover { color: var(--brand); }
    .mobile-theme-row { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--border); margin-bottom: 0.75rem; }
    .mobile-theme-row span { font-size: 0.875rem; color: var(--muted); }
    .mobile-cta { display: flex; flex-direction: column; gap: 0.625rem; }

    .btn-primary { font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 0.875rem; background: var(--brand); color: #fff; border: none; border-radius: 9999px; padding: 0.5rem 1.125rem; cursor: pointer; text-decoration: none; transition: background 0.15s, transform 0.1s; display: inline-block; white-space: nowrap; }
    .btn-primary:hover { background: var(--brand-mid); transform: translateY(-1px); }
    .btn-primary-lg { font-size: 0.9375rem; padding: 0.75rem 1.75rem; }
    .btn-secondary-lg { font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.9375rem; color: var(--muted); background: none; border: 1px solid var(--border-strong); border-radius: 9999px; padding: 0.75rem 1.75rem; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.15s; }
    .btn-secondary-lg:hover { border-color: var(--brand); color: var(--brand); }

    .hero { min-height: 100dvh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 5rem 1.25rem 4rem; text-align: center; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(5,64,96,0.12) 0%, transparent 70%), linear-gradient(180deg, rgba(10,100,144,0.07) 0%, transparent 60%); pointer-events: none; z-index: 0; }
    .hero > *:not(.hero-orb) { position: relative; z-index: 1; }
    .hero-orb { position: absolute; border-radius: 50%; pointer-events: none; }
    .hero-orb-1 { width: 600px; height: 600px; top: -220px; left: -200px; background: radial-gradient(circle, rgba(10,100,144,0.22) 0%, rgba(26,138,191,0.10) 40%, transparent 70%); filter: blur(48px); animation: drift1 22s ease-in-out infinite; }
    .hero-orb-2 { width: 500px; height: 500px; bottom: -180px; right: -180px; background: radial-gradient(circle, rgba(26,138,191,0.18) 0%, rgba(5,64,96,0.08) 45%, transparent 70%); filter: blur(56px); animation: drift2 28s ease-in-out infinite; }
    .hero-orb-4 { width: 500px; height: 500px; bottom: -180px; left: -180px; background: radial-gradient(circle, rgba(26,138,191,0.18) 0%, rgba(5,64,96,0.08) 45%, transparent 70%); filter: blur(56px); animation: drift2 19s ease-in-out infinite reverse; }
    html.dark .hero-orb-4 { background: radial-gradient(circle, rgba(56,182,232,0.22) 0%, rgba(26,138,191,0.10) 45%, transparent 70%); }
    .hero-orb-3 { width: 450px; height: 450px; top: 40%; left: 50%; background: radial-gradient(circle, rgba(26,138,191,0.08) 0%, transparent 65%); filter: blur(40px); z-index: -1; animation: drift3 33s ease-in-out infinite reverse; }


    @keyframes drift1 {
      0%,100% { transform: translate(0, 0) scale(1); }
      25% { transform: translate(35px, -20px) scale(1.03); }
      50% { transform: translate(50px, 30px) scale(1); }
      75% { transform: translate(-15px, 40px) scale(0.97); }
    }
    @keyframes drift2 {
      0%,100% { transform: translate(0, 0) scale(1); }
      25% { transform: translate(-30px, 25px) scale(0.97); }
      50% { transform: translate(-45px, -35px) scale(1.03); }
      75% { transform: translate(20px, -20px) scale(1); }
    }
    @keyframes drift3 {
      0%,100% { transform: translate(-50%, -50%) scale(1); }
      25% { transform: translate(calc(-50% + 25px), calc(-50% - 30px)) scale(1.04); }
      50% { transform: translate(calc(-50% + 40px), calc(-50% + 20px)) scale(0.96); }
      75% { transform: translate(calc(-50% - 20px), calc(-50% + 35px)) scale(1.02); }
    }
    .hero h1 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(2rem, 7vw, 5rem); font-weight: 300; letter-spacing: -0.04em; color: var(--text); line-height: 1.08; margin-bottom: 1.25rem; max-width: 780px; width: 100%; }
    .hero h1 strong { font-weight: 700; color: var(--brand); }
    .hero-sub { font-size: clamp(0.9375rem, 2vw, 1.125rem); color: var(--muted); width: 100%; max-width: 460px; margin: 0 auto 2rem; font-weight: 300; line-height: 1.75; }
    .hero-actions { display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; width: 100%; }
    .hero-meta { display: grid; grid-template-columns: 1fr 1fr; margin-top: 3rem; width: 100%; max-width: 400px; border: 1px solid var(--border); border-radius: 1rem; overflow: hidden; }
    .meta-item { text-align: center; padding: 1rem 0.75rem; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .meta-item:nth-child(2n) { border-right: none; }
    .meta-item:nth-last-child(-n+2) { border-bottom: none; }
    .meta-num { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.375rem; font-weight: 700; color: var(--brand); letter-spacing: -0.03em; display: block; }
    .meta-label { font-size: 0.7rem; color: var(--faint); font-weight: 400; }

    .divider { height: 1px; background: var(--border); }

    .how { padding: 5rem 1.25rem; max-width: 1100px; margin: 0 auto; }
    .section-label { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); display: block; margin-bottom: 1rem; }
    .section-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.625rem, 4vw, 2.75rem); font-weight: 300; letter-spacing: -0.03em; color: var(--text); line-height: 1.15; margin-bottom: 0.75rem; }
    .section-title strong { font-weight: 700; }
    .section-desc { font-size: 0.9375rem; color: var(--muted); max-width: 440px; line-height: 1.7; font-weight: 300; }

    .how-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; margin-top: 4rem; }

    .steps { display: flex; flex-direction: column; gap: 0; }
    .step {
      display: flex; gap: 1.5rem; padding: 1.75rem 0.75rem;
      border-bottom: 1px solid var(--border);
      border-radius: 0.75rem; cursor: default;
      margin-left: -0.75rem; margin-right: -0.75rem;
      transition: background 0.2s;
    }
    .step:first-child { padding-top: 0.25rem; }
    .step:last-child  { border-bottom: none; }
    .step:hover { background: rgba(26,138,191,0.04); }

    .step-num-wrap {
      flex-shrink: 0; width: 32px; height: 32px;
      border: 1px solid var(--border-strong); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.75rem; font-weight: 700; color: var(--muted); margin-top: 2px;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .step:hover .step-num-wrap { border-color: var(--accent); color: var(--accent); background: rgba(26,138,191,0.08); }

    .step-title {
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem;
      font-weight: 600; color: var(--text); margin-bottom: 0.375rem;
      letter-spacing: -0.01em;
      transition: color 0.2s, text-shadow 0.2s, font-weight 0.1s;
    }
    .step:hover .step-title {
      font-weight: 700;
      color: var(--brand);
      text-shadow: 0 0 20px rgba(26,138,191,0.4), 0 0 6px rgba(26,138,191,0.2);
    }
    html.dark .step:hover .step-title {
      color: var(--accent);
      text-shadow: 0 0 22px rgba(56,182,232,0.55), 0 0 8px rgba(56,182,232,0.3);
    }
    .step-desc { font-size: 0.875rem; color: var(--muted); line-height: 1.65; font-weight: 300; }

    .how-right { display: flex; flex-direction: column; gap: 0.875rem; }
    .how-visual { background: var(--surface); border: 1px solid var(--border); border-radius: 1.5rem; padding: 2rem; display: flex; flex-direction: column; gap: 1rem; }
    .mock-header { display: flex; align-items: center; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
    .mock-title  { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.875rem; font-weight: 600; color: var(--text); }
    .mock-badge  { background: #dcfce7; color: var(--green); font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.625rem; border-radius: 9999px; }
    .mock-card   { background: var(--bg); border: 1px solid var(--border); border-radius: 0.875rem; padding: 1rem 1.125rem; display: flex; align-items: center; gap: 0.875rem; }
    .mock-avatar { width: 38px; height: 38px; border-radius: 50%; background: linear-gradient(135deg, var(--brand-mid), var(--accent)); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.75rem; font-weight: 700; color: #fff; }
    .mock-info   { flex: 1; }
    .mock-name   { font-size: 0.8125rem; font-weight: 600; color: var(--text); }
    .mock-role   { font-size: 0.75rem; color: var(--faint); }
    .mock-stars  { color: #f59e0b; font-size: 0.7rem; }
    .mock-map    { background: linear-gradient(135deg, #e6f0f5 0%, #b3d4e3 100%); border-radius: 0.875rem; height: 120px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
    .mock-map-pin   { width: 28px; height: 28px; background: var(--brand); border-radius: 50% 50% 50% 0; transform: rotate(-45deg); box-shadow: 0 4px 12px rgba(5,64,96,0.3); }
    .mock-map-pulse { position: absolute; width: 50px; height: 50px; border: 2px solid rgba(5,64,96,0.2); border-radius: 50%; animation: expand 2s infinite; }
    @keyframes expand { 0% { transform: scale(0.5); opacity: 1; } 100% { transform: scale(2); opacity: 0; } }
    .mock-eta   { display: flex; align-items: center; justify-content: space-between; }
    .mock-eta-label { font-size: 0.75rem; color: var(--faint); }
    .mock-eta-val   { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.875rem; font-weight: 700; color: var(--brand); }

    .step-preview-container { overflow: hidden; max-height: 0; transition: max-height 0.38s cubic-bezier(0.4,0,0.2,1); }
    .step-preview-container.open { max-height: 220px; }
    .step-preview {
      background: var(--surface); border: 1px solid var(--accent); border-radius: 1.25rem;
      padding: 1rem 1.125rem; display: none; flex-direction: column; gap: 0.625rem;
      box-shadow: 0 4px 20px rgba(26,138,191,0.10), 0 0 0 1px rgba(26,138,191,0.06);
      opacity: 0; transform: translateY(6px); transition: opacity 0.22s ease, transform 0.22s ease;
    }
    .step-preview.visible { opacity: 1; transform: translateY(0); }
    .preview-label { font-size: 0.6875rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); display: flex; align-items: center; gap: 0.375rem; }
    .preview-label::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--accent); display: inline-block; }

    .prev-service-grid { display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .prev-chip { border: 1px solid var(--border); border-radius: 9999px; padding: 0.25rem 0.65rem; font-size: 0.695rem; font-weight: 500; color: var(--muted); background: var(--bg); }
    .prev-chip.sel { border-color: var(--accent); color: var(--accent); background: rgba(26,138,191,0.08); }
    .prev-input { background: var(--bg); border: 1px solid var(--border); border-radius: 0.5rem; padding: 0.4rem 0.7rem; font-size: 0.72rem; color: var(--faint); display: flex; align-items: center; gap: 0.5rem; }
    .prev-cursor { width: 1px; height: 11px; background: var(--accent); animation: blink 1s infinite; }
    @keyframes blink { 0%,100%{opacity:1}50%{opacity:0} }

    .prev-match-list { display: flex; flex-direction: column; gap: 0.4rem; }
    .prev-match-row { display: flex; align-items: center; gap: 0.55rem; background: var(--bg); border-radius: 0.5rem; padding: 0.45rem 0.6rem; border: 1px solid var(--border); }
    .prev-match-row.top { border-color: var(--accent); }
    .prev-av { width: 26px; height: 26px; border-radius: 50%; background: linear-gradient(135deg, var(--brand-mid), var(--accent)); display: flex; align-items: center; justify-content: center; font-size: 0.58rem; font-weight: 700; color: #fff; flex-shrink: 0; }
    .prev-mi { flex: 1; }
    .prev-mn { font-size: 0.7rem; font-weight: 600; color: var(--text); }
    .prev-md { font-size: 0.63rem; color: var(--faint); }
    .prev-sc { font-size: 0.63rem; font-weight: 700; color: var(--accent); background: rgba(26,138,191,0.1); border-radius: 9999px; padding: 0.12rem 0.38rem; }

    .prev-track { background: linear-gradient(135deg, #e6f0f5, #b3d4e3); border-radius: 0.625rem; height: 58px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
    .prev-pin { width: 16px; height: 16px; background: var(--brand); border-radius: 50% 50% 50% 0; transform: rotate(-45deg); box-shadow: 0 2px 8px rgba(5,64,96,0.35); position: relative; z-index: 1; }
    .prev-pulse { position: absolute; width: 28px; height: 28px; border: 1.5px solid rgba(5,64,96,0.25); border-radius: 50%; animation: expand 2s infinite 0.3s; }
    .prev-eta-row { display: flex; align-items: center; justify-content: space-between; }
    .prev-eta-txt { font-size: 0.68rem; color: var(--faint); }
    .prev-eta-val { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.78rem; font-weight: 700; color: var(--brand); }

    .prev-done-row { display: flex; align-items: center; gap: 0.55rem; background: var(--bg); border-radius: 0.5rem; padding: 0.45rem 0.7rem; border: 1px solid #dcfce7; }
    .prev-chk { width: 20px; height: 20px; border-radius: 50%; background: #dcfce7; color: var(--green); display: flex; align-items: center; justify-content: center; font-size: 0.58rem; font-weight: 700; flex-shrink: 0; }
    .prev-done-txt { font-size: 0.72rem; font-weight: 500; color: var(--text); }
    .prev-rating-row { display: flex; align-items: center; justify-content: space-between; padding: 0 0.2rem; }
    .prev-rlabel { font-size: 0.68rem; color: var(--muted); }
    .prev-stars { display: flex; gap: 0.15rem; }
    .prev-stars span { font-size: 0.95rem; color: #f59e0b; }

    .services-section { background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 5rem 1.25rem; }
    .services-inner   { max-width: 1100px; margin: 0 auto; }
    .services-header  { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2.5rem; gap: 1.5rem; flex-wrap: wrap; }
    .services-grid    { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.625rem; }
    .service-chip     { border: 1px solid var(--border); border-radius: 0.875rem; padding: 1.25rem 0.75rem; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; text-align: center; transition: all 0.15s; background: var(--bg); }
    .service-chip:hover { border-color: var(--brand-mid); background: #e6f0f5; transform: translateY(-2px); }
    .service-icon { width: 26px; height: 26px; color: var(--brand-mid); }
    .service-name { font-size: 0.75rem; font-weight: 500; color: var(--text); }

    .testimonials-section { background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 5rem 1.25rem; }
    .testimonials-inner   { max-width: 1100px; margin: 0 auto; }
    .testimonials-grid    { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-top: 3rem; }
    .testimonial-card     { border: 1px solid var(--border); border-radius: 1.25rem; padding: 1.75rem; background: var(--bg); display: flex; flex-direction: column; gap: 1.25rem; transition: border-color 0.15s, box-shadow 0.15s; }
    .testimonial-card:hover { border-color: var(--border-strong); box-shadow: 0 4px 24px rgba(0,0,0,0.06); }
    .stars { color: #f59e0b; font-size: 0.875rem; letter-spacing: 1px; }
    .testimonial-text   { font-size: 0.9375rem; color: var(--muted); line-height: 1.75; font-weight: 300; font-style: italic; flex: 1; }
    .testimonial-author { display: flex; align-items: center; gap: 0.75rem; }
    .author-avatar { width: 38px; height: 38px; border-radius: 50%; background: linear-gradient(135deg, var(--brand), var(--accent)); display: flex; align-items: center; justify-content: center; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.75rem; font-weight: 700; color: #fff; flex-shrink: 0; }
    .author-name { font-size: 0.875rem; font-weight: 600; color: var(--text); }
    .author-role { font-size: 0.75rem; color: var(--faint); }

    .providers-section { background: var(--brand); padding: 5rem 1.25rem; }
    .providers-inner   { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .providers-tag     { display: inline-block; background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.3rem 0.875rem; border-radius: 9999px; margin-bottom: 1.5rem; }
    .providers-title   { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.625rem, 3vw, 2.5rem); font-weight: 300; color: #fff; letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 1rem; }
    .providers-title strong { font-weight: 700; }
    .providers-desc    { font-size: 0.9375rem; color: rgba(255,255,255,0.65); line-height: 1.75; font-weight: 300; margin-bottom: 2rem; }
    .benefits          { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
    .benefits li       { display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; color: rgba(255,255,255,0.8); }
    .benefit-check     { width: 18px; height: 18px; background: rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.625rem; color: #fff; }
    .btn-white         { display: inline-block; font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 0.9375rem; background: #fff; color: var(--brand); border: none; border-radius: 9999px; padding: 0.75rem 1.75rem; cursor: pointer; text-decoration: none; transition: all 0.15s; margin-top: 2rem; }
    .btn-white:hover   { box-shadow: 0 8px 24px rgba(0,0,0,0.15); transform: translateY(-1px); }
    .provider-stats    { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .pstat             { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); border-radius: 1rem; padding: 1.5rem; }
    .pstat-num         { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #fff; letter-spacing: -0.03em; display: block; margin-bottom: 0.25rem; }
    .pstat-label       { font-size: 0.8rem; color: rgba(255,255,255,0.5); }
    .pstat-wide        { grid-column: span 2; }

    .faq-section { padding: 5rem 1.25rem; max-width: 680px; margin: 0 auto; }
    .faq-list    { margin-top: 3rem; }
    .faq-item    { border-bottom: 1px solid var(--border); }
    .faq-q       { width: 100%; background: none; border: none; padding: 1.25rem 0; display: flex; align-items: center; justify-content: space-between; gap: 1rem; cursor: pointer; text-align: left; font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; font-weight: 500; color: var(--text); transition: color 0.15s; }
    .faq-q:hover { color: var(--brand); }
    .faq-icon    { width: 20px; height: 20px; border: 1px solid var(--border-strong); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.7rem; color: var(--muted); transition: transform 0.25s, background 0.15s, border-color 0.15s; }
    .faq-item.open .faq-icon { transform: rotate(45deg); background: var(--brand); border-color: var(--brand); color: #fff; }
    .faq-a       { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; font-size: 0.875rem; color: var(--muted); line-height: 1.75; font-weight: 300; }
    .faq-item.open .faq-a { max-height: 200px; padding-bottom: 1.5rem; }

    footer { border-top: 1px solid var(--border); padding: 1.75rem 1.25rem; }
    .footer-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.75rem; }
    .footer-copy  { font-size: 0.8rem; color: var(--faint); }
    .footer-links { display: flex; gap: 1.25rem; }
    .footer-links a { font-size: 0.8rem; color: var(--faint); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--text); }

    .scroll-top { position: fixed; bottom: 1.5rem; right: 1.5rem; width: 40px; height: 40px; background: var(--brand); color: #fff; border: 2px solid rgba(255,255,255,0.6); border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(5,64,96,0.25); opacity: 0; transform: translateY(10px); transition: opacity 0.25s, transform 0.25s, background 0.15s; pointer-events: none; z-index: 99; }
    .scroll-top.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .scroll-top:hover { background: var(--brand-mid); }

    .fade-up { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    @media (min-width: 769px) {
      .mobile-header-actions { display: none !important; }
      .mobile-menu { display: none !important; }
    }
    @media (max-width: 768px) {
      .desktop-nav { display: none; }
      .hamburger   { display: flex; }
      .header-btns { display: none; }
      .mobile-header-actions { display: flex !important; }
      .mobile-header-actions .btn-ghost { font-size: 0.8125rem; padding: 0.4rem 0.75rem; border: 1px solid var(--border-strong); border-radius: 9999px; color: var(--text); }
    }
    @media (max-width: 900px) {
      .desktop-nav { display: none; }
      .hamburger   { display: flex; }
      .header-btns .theme-toggle { display: none; }
      .header-btns .btn-primary  { display: none; }
      .how-grid        { grid-template-columns: 1fr; gap: 3rem; }
      .providers-inner { grid-template-columns: 1fr; gap: 3rem; }
      .hero-meta       { max-width: 480px; }
      .step-preview-container { display: none; }
    }
    @media (max-width: 480px) {
      header { padding: 0 1rem; height: 56px; }
      .logo img { height: 32px; }
      .hero { padding: 4.5rem 1rem 3rem; }
      .hero-orb-1 { width: 300px; height: 300px; top: -100px; left: -100px; }
      .hero-orb-2 { width: 260px; height: 260px; bottom: -80px; right: -80px; }
      .hero-orb-3 { width: 200px; height: 200px; }
      .hero-actions { flex-direction: column; }
      .hero-actions .btn-primary-lg, .hero-actions .btn-secondary-lg { width: 100%; justify-content: center; }
      .hero-meta { max-width: 100%; }
      .how, .services-section, .testimonials-section, .providers-section, .faq-section { padding: 4rem 1rem; }
      .services-grid { grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
      .service-chip  { padding: 1rem 0.5rem; }
      .testimonials-grid { grid-template-columns: 1fr; }
      .footer-inner { flex-direction: column; align-items: flex-start; }
    }
    @media (max-width: 360px) {
      .hero h1 { font-size: 1.875rem; }
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .btn-primary { padding: 0.5rem 0.875rem; font-size: 0.8125rem; }
    }
  </style>
</head>
<body>

  <header>
    <a href="/" class="logo"><img src="logo.png" alt="Aliados" /></a>
    <div class="header-right">
      <nav class="desktop-nav">
        <a href="#como-funciona">Cómo funciona</a>
        <a href="#servicios">Servicios</a>
        <a href="#proveedores">Para profesionales</a>
        <a href="#faq">FAQ</a>
      </nav>
      <div class="header-btns">
        <button class="theme-toggle" id="themeToggle" aria-label="Cambiar tema">
          <span class="toggle-thumb">
            <svg class="icon-sun" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon-moon" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
          </span>
        </button>
        <a href={LOGIN_URL} class="btn-ghost">Iniciar sesión</a>
        <a href={REGISTER_URL} class="btn-primary">Empezar gratis</a>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:0.375rem;" class="mobile-header-actions">
      <a href={LOGIN_URL} class="btn-primary" style="font-size:0.8125rem;padding:0.4rem 0.875rem;">Iniciar sesión</a>
      <button class="hamburger" id="hamburger" aria-label="Menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Menú de navegación">
    <nav class="mobile-nav">
      <a href="#como-funciona">Cómo funciona</a>
      <a href="#servicios">Servicios</a>
      <a href="#proveedores">Para profesionales</a>
      <a href="#faq">FAQ</a>
    </nav>
    <div class="mobile-theme-row">
      <span>Tema</span>
      <button class="theme-toggle" id="themeToggleMobile" aria-label="Cambiar tema">
        <span class="toggle-thumb">
          <svg class="icon-sun" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icon-moon" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
        </span>
      </button>
    </div>
    <div class="mobile-cta">
      <a href={REGISTER_URL} class="btn-primary btn-primary-lg" style="text-align:center;">Empezar gratis</a>
    </div>
  </div>

  <section class="hero">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <div class="hero-orb hero-orb-4"></div>
    <h1>El profesional que necesitás,<br/><strong>cuando lo necesitás.</strong></h1>
    <p class="hero-sub">Conectamos clientes con profesionales verificados en minutos. Sin intermediarios, sin esperas.</p>
    <div class="hero-actions">
      <a href={REGISTER_URL} class="btn-primary btn-primary-lg">Solicitar un servicio</a>
      <a href="#como-funciona" class="btn-secondary-lg">
        Ver cómo funciona
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="hero-meta">
      <div class="meta-item"><span class="meta-num">+1.200</span><span class="meta-label">Servicios completados</span></div>
      <div class="meta-item"><span class="meta-num">+180</span><span class="meta-label">Profesionales activos</span></div>
      <div class="meta-item"><span class="meta-num">4.8★</span><span class="meta-label">Calificación promedio</span></div>
      <div class="meta-item"><span class="meta-num">&lt;8 min</span><span class="meta-label">Tiempo de respuesta</span></div>
    </div>
  </section>

  <div class="divider"></div>

  <section class="how" id="como-funciona">
    <div class="how-grid">
      <div>
        <div class="fade-up">
          <span class="section-label">Proceso</span>
          <h2 class="section-title">Simple de usar.<br/><strong>Rápido de resolver.</strong></h2>
          <p class="section-desc">De la solicitud al trabajo terminado, todo dentro de la plataforma.</p>
        </div>
        <div class="steps" style="margin-top:3rem">
          <div class="step fade-up" data-step="1">
            <div class="step-num-wrap">01</div>
            <div class="step-body">
              <div class="step-title">Describí lo que necesitás</div>
              <p class="step-desc">Seleccioná el tipo de servicio y contanos brevemente el problema. En segundos.</p>
            </div>
          </div>
          <div class="step fade-up" style="transition-delay:0.1s" data-step="2">
            <div class="step-num-wrap">02</div>
            <div class="step-body">
              <div class="step-title">Match automático</div>
              <p class="step-desc">El sistema conecta tu solicitud con los mejores profesionales disponibles cerca tuyo.</p>
            </div>
          </div>
          <div class="step fade-up" style="transition-delay:0.2s" data-step="3">
            <div class="step-num-wrap">03</div>
            <div class="step-body">
              <div class="step-title">Coordinación en tiempo real</div>
              <p class="step-desc">Seguí la ubicación del profesional y comunicate directamente desde la app.</p>
            </div>
          </div>
          <div class="step fade-up" style="transition-delay:0.3s" data-step="4">
            <div class="step-num-wrap">04</div>
            <div class="step-body">
              <div class="step-title">Trabajo completado</div>
              <p class="step-desc">Confirmá la finalización, calificá el servicio. Simple y transparente.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="how-right fade-up">
        <div class="how-visual">
          <div class="mock-header">
            <span class="mock-title">Servicio en curso</span>
            <span class="mock-badge">En camino</span>
          </div>
          <div class="mock-card">
            <div class="mock-avatar">RL</div>
            <div class="mock-info">
              <div class="mock-name">Roberto L.</div>
              <div class="mock-role">Electricista · 4 años</div>
            </div>
            <div class="mock-stars">★★★★★</div>
          </div>
          <div class="mock-map">
            <div class="mock-map-pulse"></div>
            <div class="mock-map-pin"></div>
          </div>
          <div class="mock-eta">
            <span class="mock-eta-label">Tiempo estimado de llegada</span>
            <span class="mock-eta-val">~6 min</span>
          </div>
        </div>

        <div class="step-preview-container" id="previewContainer">
          <div class="step-preview" id="preview-1">
            <div class="preview-label">Paso 1 — En la app</div>
            <div class="prev-service-grid">
              <span class="prev-chip sel">⚡ Electricista</span>
              <span class="prev-chip">🔧 Plomero</span>
              <span class="prev-chip">🔑 Cerrajero</span>
              <span class="prev-chip">❄️ Aire acond.</span>
            </div>
            <div class="prev-input">
              <span style="flex:1">Describí brevemente el problema...</span>
              <div class="prev-cursor"></div>
            </div>
          </div>
          <div class="step-preview" id="preview-2">
            <div class="preview-label">Paso 2 — En la app</div>
            <div class="prev-match-list">
              <div class="prev-match-row top">
                <div class="prev-av">RL</div>
                <div class="prev-mi"><div class="prev-mn">Roberto L.</div><div class="prev-md">350m · disponible ahora</div></div>
                <span class="prev-sc">★ 4.9</span>
              </div>
              <div class="prev-match-row">
                <div class="prev-av" style="background:linear-gradient(135deg,#16a34a,#4ade80)">MF</div>
                <div class="prev-mi"><div class="prev-mn">Marcelo F.</div><div class="prev-md">600m · disponible</div></div>
                <span class="prev-sc">★ 4.7</span>
              </div>
            </div>
          </div>
          <div class="step-preview" id="preview-3">
            <div class="preview-label">Paso 3 — En la app</div>
            <div class="prev-track">
              <div class="prev-pulse"></div>
              <div class="prev-pin"></div>
            </div>
            <div class="prev-eta-row">
              <span class="prev-eta-txt">Llegada estimada</span>
              <span class="prev-eta-val">~6 min</span>
            </div>
          </div>
          <div class="step-preview" id="preview-4">
            <div class="preview-label">Paso 4 — En la app</div>
            <div class="prev-done-row">
              <div class="prev-chk">✓</div>
              <span class="prev-done-txt">Trabajo confirmado por el cliente</span>
            </div>
            <div class="prev-rating-row">
              <span class="prev-rlabel">Calificá a Roberto L.</span>
              <div class="prev-stars">
                <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <section class="services-section" id="servicios">
    <div class="services-inner">
      <div class="services-header">
        <div class="fade-up">
          <span class="section-label">Categorías</span>
          <h2 class="section-title">Todos los servicios<br/><strong>del hogar.</strong></h2>
        </div>
        <p class="section-desc fade-up" style="transition-delay:0.1s">Profesionales calificados para cada necesidad.</p>
      </div>
      <div class="services-grid">
        <div class="service-chip fade-up"><svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L4.5 13.5H12L11 22L19.5 10.5H12L13 2Z"/></svg><span class="service-name">Electricista</span></div>
        <div class="service-chip fade-up" style="transition-delay:0.05s"><svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg><span class="service-name">Plomero</span></div>
        <div class="service-chip fade-up" style="transition-delay:0.1s"><svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg><span class="service-name">Cerrajero</span></div>
        <div class="service-chip fade-up" style="transition-delay:0.15s"><svg class="service-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="8" rx="2"/><path d="M7 11v4a2 2 0 002 2h6a2 2 0 002-2v-4"/><path d="M12 15v4M8 19h8"/></svg><span class="service-name">Aire acond.</span></div>
