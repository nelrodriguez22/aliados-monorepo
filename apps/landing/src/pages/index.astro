---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'https://aliados-app-22.web.app';
const LOGIN_URL = `${APP_URL}/login`;
const REGISTER_URL = `${APP_URL}/registro`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aliados — El profesional que necesitás, cuando lo necesitás</title>
  <meta name="description" content="Conectamos clientes con profesionales de confianza en Rosario. Electricistas, plomeros, cerrajeros y más." />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --brand:         #054060;
      --brand-mid:     #0a6490;
      --accent:        #1a8abf;
      --green:         #16a34a;
      --bg:            #fafafa;
      --surface:       #ffffff;
      --border:        #e8e8e8;
      --border-strong: #d0d0d0;
      --text:          #0f1117;
      --muted:         #6b7280;
      --faint:         #9ca3af;
    }

    html { scroll-behavior: smooth; }

    html.dark {
      --brand:         #1a8abf;
      --brand-mid:     #1e9fd6;
      --accent:        #38b6e8;
      --green:         #4ade80;
      --bg:            #0f1117;
      --surface:       #161b27;
      --border:        #1e2535;
      --border-strong: #2a3347;
      --text:          #e8eaf0;
      --muted:         #7a8499;
      --faint:         #4a5568;
    }

    /* ── FONTS ── */
    @font-face {
      font-family: 'Plus Jakarta Sans';
      src: url('/fonts/PlusJakartaSans-Variable.woff2') format('woff2');
      font-weight: 300 700;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: 'DM Sans';
      src: url('/fonts/DMSans-Variable.woff2') format('woff2');
      font-weight: 300 500;
      font-style: normal;
      font-display: swap;
    }

    /* ── DARK OVERRIDES ── */
    html.dark .services-section  { background: var(--surface); }
    html.dark .how-visual        { background: var(--surface); }
    html.dark .mock-card         { background: var(--bg); }
    html.dark .mock-map          { background: linear-gradient(135deg, #0a1929 0%, #0d2137 100%); }
    html.dark .testimonial-card  { background: var(--surface); }
    html.dark header             { background: rgba(15,17,23,0.92); }
    html.dark .providers-section { background: #0a1929; }
    html.dark .providers-tag     { background: rgba(26,138,191,0.15); color: var(--accent); }
    html.dark .faq-section       { background: var(--bg); }
    html.dark .final-cta         { background: var(--bg); }

    /* ── THEME TOGGLE ── */
    .theme-toggle {
      width: 52px; height: 28px;
      background: var(--border-strong);
      border-radius: 9999px; border: none;
      cursor: pointer; position: relative;
      transition: background 0.3s;
      flex-shrink: 0; padding: 0;
    }
    html.dark .theme-toggle { background: var(--brand); }
    .toggle-thumb {
      position: absolute; top: 3px; left: 3px;
      width: 22px; height: 22px; background: white;
      border-radius: 50%;
      transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
      display: flex; align-items: center; justify-content: center;
      color: #f59e0b; box-shadow: 0 1px 4px rgba(0,0,0,0.15);
    }
    html.dark .toggle-thumb { transform: translateX(24px); color: #94a3b8; }
    .icon-sun, .icon-moon { position: absolute; transition: opacity 0.2s; }
    .icon-sun  { opacity: 1; }
    .icon-moon { opacity: 0; }
    html.dark .icon-sun  { opacity: 0; }
    html.dark .icon-moon { opacity: 1; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg); color: var(--text);
      overflow-x: hidden; line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── HEADER ── */
    header {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100; height: 60px;
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      background: rgba(250,250,250,0.7);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .logo img { height: 36px; }

    /* desktop nav */
    .desktop-nav { display: flex; align-items: center; gap: 2rem; }
    .desktop-nav a { font-size: 0.875rem; font-weight: 400; color: var(--muted); text-decoration: none; transition: color 0.15s; }
    .desktop-nav a:hover { color: var(--text); }
    .header-right { display: flex; align-items: center; gap: 0.5rem; }

    .btn-ghost {
      font-size: 0.875rem; font-weight: 500; color: var(--muted);
      background: none; border: none; cursor: pointer;
      text-decoration: none; padding: 0.5rem 0.625rem;
      transition: color 0.15s; white-space: nowrap;
    }
    .btn-ghost:hover { color: var(--text); }

    /* ── HAMBURGER ── */
    .hamburger {
      display: none;
      flex-direction: column; justify-content: center; align-items: center;
      gap: 5px; width: 36px; height: 36px;
      background: none; border: none; cursor: pointer;
      padding: 4px; border-radius: 8px;
      transition: background 0.15s; flex-shrink: 0;
    }
    .hamburger:hover { background: var(--border); }
    .hamburger span {
      display: block; width: 20px; height: 2px;
      background: var(--text); border-radius: 2px;
      transition: transform 0.25s ease, opacity 0.2s ease;
      transform-origin: center;
    }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── MOBILE MENU ── */
    .mobile-menu {
      display: none; position: fixed;
      top: 60px; left: 0; right: 0; z-index: 98;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 1.25rem 1.5rem;
      flex-direction: column; gap: 0;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      animation: slideDown 0.2s ease;
    }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
    .mobile-menu.open { display: flex; }

    .mobile-nav { display: flex; flex-direction: column; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.75rem; }
    .mobile-nav a { font-size: 0.9375rem; font-weight: 500; color: var(--text); padding: 0.75rem 0; border-bottom: 1px solid var(--border); text-decoration: none; transition: color 0.15s; }
    .mobile-nav a:last-child { border-bottom: none; }
    .mobile-nav a:hover { color: var(--brand); }

    .mobile-theme-row { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--border); margin-bottom: 0.75rem; }
    .mobile-theme-row span { font-size: 0.875rem; color: var(--muted); }

    .mobile-cta { display: flex; flex-direction: column; gap: 0.625rem; }

    .btn-primary {
      font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 0.875rem;
      background: var(--brand); color: #fff; border: none;
      border-radius: 9999px; padding: 0.5rem 1.125rem;
      cursor: pointer; text-decoration: none;
      transition: background 0.15s, transform 0.1s;
      display: inline-block; white-space: nowrap;
    }
    .btn-primary:hover { background: var(--brand-mid); transform: translateY(-1px); }
    .btn-primary-lg { font-size: 0.9375rem; padding: 0.75rem 1.75rem; }

    .btn-secondary-lg {
      font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.9375rem;
      color: var(--muted); background: none;
      border: 1px solid var(--border-strong); border-radius: 9999px;
      padding: 0.75rem 1.75rem; cursor: pointer; text-decoration: none;
      display: inline-flex; align-items: center; gap: 0.5rem;
      transition: all 0.15s;
    }
    .btn-secondary-lg:hover { border-color: var(--brand); color: var(--brand); }

    /* ── HERO ── */
    .hero {
      min-height: 100dvh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 5rem 1.25rem 4rem;
      text-align: center; position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; top: 0; left: 50%;
      transform: translateX(-50%);
      width: min(800px, 100%); height: 600px;
      background: radial-gradient(ellipse at top, rgba(5,64,96,0.05) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-orb { position: absolute; border-radius: 50%; pointer-events: none; }
    .hero-orb-1 {
      width: 500px; height: 500px; top: -200px; left: -180px;
      background: radial-gradient(circle, rgba(10,100,144,0.10) 0%, transparent 65%);
      animation: drift1 12s ease-in-out infinite;
    }
    .hero-orb-2 {
      width: 400px; height: 400px; bottom: -150px; right: -150px;
      background: radial-gradient(circle, rgba(26,138,191,0.08) 0%, transparent 65%);
      animation: drift2 15s ease-in-out infinite;
    }
    @keyframes drift1 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(20px,15px); } }
    @keyframes drift2 { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-15px,-20px); } }

    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.8125rem; font-weight: 500;
      color: var(--accent); letter-spacing: 0.04em; margin-bottom: 1.5rem;
    }
    .eyebrow-dot {
      width: 6px; height: 6px; background: var(--green);
      border-radius: 50%; animation: blink 2s infinite; flex-shrink: 0;
    }
    @keyframes blink { 0%,100% { opacity:1; } 50% { opacity:0.3; } }

    .hero h1 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(2rem, 7vw, 5rem);
      font-weight: 300; letter-spacing: -0.04em;
      color: var(--text); line-height: 1.08;
      margin-bottom: 1.25rem; max-width: 780px; width: 100%;
    }
    .hero h1 strong { font-weight: 700; color: var(--brand); }

    .hero-sub {
      font-size: clamp(0.9375rem, 2vw, 1.125rem);
      color: var(--muted); width: 100%; max-width: 460px;
      margin: 0 auto 2rem; font-weight: 300; line-height: 1.75;
    }

    .hero-actions {
      display: flex; align-items: center; justify-content: center;
      gap: 0.75rem; flex-wrap: wrap; width: 100%;
    }

    /* Stats: grid 2×2 siempre en mobile, flex en desktop */
    .hero-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      margin-top: 3rem; width: 100%; max-width: 400px;
      border: 1px solid var(--border); border-radius: 1rem; overflow: hidden;
    }
    .meta-item {
      text-align: center; padding: 1rem 0.75rem;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .meta-item:nth-child(2n)      { border-right: none; }
    .meta-item:nth-last-child(-n+2) { border-bottom: none; }
    .meta-sep { display: none; } /* ocultar separadores verticales legacy */
    .meta-num {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1.375rem; font-weight: 700;
      color: var(--brand); letter-spacing: -0.03em; display: block;
    }
    .meta-label { font-size: 0.7rem; color: var(--faint); font-weight: 400; }

    /* ── DIVIDER ── */
    .divider { height: 1px; background: var(--border); }

    /* ── HOW IT WORKS ── */
    .how { padding: 5rem 1.25rem; max-width: 1100px; margin: 0 auto; }

    .section-label {
      font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--accent);
      display: block; margin-bottom: 1rem;
    }
    .section-title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(1.625rem, 4vw, 2.75rem);
      font-weight: 300; letter-spacing: -0.03em;
      color: var(--text); line-height: 1.15; margin-bottom: 0.75rem;
    }
    .section-title strong { font-weight: 700; }
    .section-desc { font-size: 0.9375rem; color: var(--muted); max-width: 440px; line-height: 1.7; font-weight: 300; }

    .how-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 5rem; align-items: start; margin-top: 4rem;
    }
    .steps { display: flex; flex-direction: column; gap: 0; }
    .step {
      display: flex; gap: 1.5rem; padding: 2rem 0;
      border-bottom: 1px solid var(--border);
    }
    .step:first-child { padding-top: 0; }
    .step:last-child  { border-bottom: none; }
    .step-num-wrap {
      flex-shrink: 0; width: 32px; height: 32px;
      border: 1px solid var(--border-strong); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.75rem; font-weight: 700; color: var(--muted); margin-top: 2px;
    }
    .step-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: 0.375rem; letter-spacing: -0.01em; }
    .step-desc  { font-size: 0.875rem; color: var(--muted); line-height: 1.65; font-weight: 300; }

    .how-visual {
      position: sticky; top: 80px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 1.5rem; padding: 2rem;
      display: flex; flex-direction: column; gap: 1rem;
    }
    .mock-header { display: flex; align-items: center; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
    .mock-title  { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.875rem; font-weight: 600; color: var(--text); }
    .mock-badge  { background: #dcfce7; color: var(--green); font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.625rem; border-radius: 9999px; }
    .mock-card   { background: var(--bg); border: 1px solid var(--border); border-radius: 0.875rem; padding: 1rem 1.125rem; display: flex; align-items: center; gap: 0.875rem; }
    .mock-avatar { width: 38px; height: 38px; border-radius: 50%; background: linear-gradient(135deg, var(--brand-mid), var(--accent)); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.75rem; font-weight: 700; color: #fff; }
    .mock-info   { flex: 1; }
    .mock-name   { font-size: 0.8125rem; font-weight: 600; color: var(--text); }
    .mock-role   { font-size: 0.75rem; color: var(--faint); }
    .mock-stars  { color: #f59e0b; font-size: 0.7rem; }
    .mock-map    { background: linear-gradient(135deg, #e6f0f5 0%, #b3d4e3 100%); border-radius: 0.875rem; height: 120px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
    .mock-map-pin   { width: 28px; height: 28px; background: var(--brand); border-radius: 50% 50% 50% 0; transform: rotate(-45deg); box-shadow: 0 4px 12px rgba(5,64,96,0.3); }
    .mock-map-pulse { position: absolute; width: 50px; height: 50px; border: 2px solid rgba(5,64,96,0.2); border-radius: 50%; animation: expand 2s infinite; }
    @keyframes expand { 0% { transform: scale(0.5); opacity: 1; } 100% { transform: scale(2); opacity: 0; } }
    .mock-eta       { display: flex; align-items: center; justify-content: space-between; }
    .mock-eta-label { font-size: 0.75rem; color: var(--faint); }
    .mock-eta-val   { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.875rem; font-weight: 700; color: var(--brand); }

    /* ── SERVICES ── */
    .services-section { background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 5rem 1.25rem; }
    .services-inner   { max-width: 1100px; margin: 0 auto; }
    .services-header  { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2.5rem; gap: 1.5rem; flex-wrap: wrap; }
    .services-grid    { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 0.625rem; }
    .service-chip     { border: 1px solid var(--border); border-radius: 0.875rem; padding: 1.25rem 0.75rem; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; text-align: center; transition: all 0.15s; background: var(--bg); }
    .service-chip:hover { border-color: var(--brand-mid); background: #e6f0f5; transform: translateY(-2px); }
    .service-icon { width: 26px; height: 26px; color: var(--brand-mid); }
    .service-name { font-size: 0.75rem; font-weight: 500; color: var(--text); }

    /* ── TESTIMONIALS ── */
    .testimonials-section { padding: 5rem 1.25rem; max-width: 1100px; margin: 0 auto; }
    .testimonials-grid    { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; margin-top: 3rem; }
    .testimonial-card     { border: 1px solid var(--border); border-radius: 1.25rem; padding: 1.75rem; background: var(--surface); display: flex; flex-direction: column; gap: 1.25rem; transition: border-color 0.15s, box-shadow 0.15s; }
    .testimonial-card:hover { border-color: var(--border-strong); box-shadow: 0 4px 24px rgba(0,0,0,0.06); }
    .stars { color: #f59e0b; font-size: 0.875rem; letter-spacing: 1px; }
    .testimonial-text   { font-size: 0.9375rem; color: var(--muted); line-height: 1.75; font-weight: 300; font-style: italic; flex: 1; }
    .testimonial-author { display: flex; align-items: center; gap: 0.75rem; }
    .author-avatar { width: 38px; height: 38px; border-radius: 50%; background: linear-gradient(135deg, var(--brand), var(--accent)); display: flex; align-items: center; justify-content: center; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.75rem; font-weight: 700; color: #fff; flex-shrink: 0; }
    .author-name { font-size: 0.875rem; font-weight: 600; color: var(--text); }
    .author-role { font-size: 0.75rem; color: var(--faint); }

    /* ── PROVIDERS ── */
    .providers-section { background: var(--brand); padding: 5rem 1.25rem; }
    .providers-inner   { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .providers-tag     { display: inline-block; background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.3rem 0.875rem; border-radius: 9999px; margin-bottom: 1.5rem; }
    .providers-title   { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.625rem, 3vw, 2.5rem); font-weight: 300; color: #fff; letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 1rem; }
    .providers-title strong { font-weight: 700; }
    .providers-desc    { font-size: 0.9375rem; color: rgba(255,255,255,0.65); line-height: 1.75; font-weight: 300; margin-bottom: 2rem; }
    .benefits          { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
    .benefits li       { display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; color: rgba(255,255,255,0.8); }
    .benefit-check     { width: 18px; height: 18px; background: rgba(255,255,255,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.625rem; color: #fff; }
    .btn-white         { display: inline-block; font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 0.9375rem; background: #fff; color: var(--brand); border: none; border-radius: 9999px; padding: 0.75rem 1.75rem; cursor: pointer; text-decoration: none; transition: all 0.15s; margin-top: 2rem; }
    .btn-white:hover   { box-shadow: 0 8px 24px rgba(0,0,0,0.15); transform: translateY(-1px); }
    .provider-stats    { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .pstat             { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); border-radius: 1rem; padding: 1.5rem; }
    .pstat-num         { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.75rem; font-weight: 700; color: #fff; letter-spacing: -0.03em; display: block; margin-bottom: 0.25rem; }
    .pstat-label       { font-size: 0.8rem; color: rgba(255,255,255,0.5); }
    .pstat-wide        { grid-column: span 2; }

    /* ── FAQ ── */
    .faq-section { padding: 5rem 1.25rem; max-width: 680px; margin: 0 auto; }
    .faq-list    { margin-top: 3rem; }
    .faq-item    { border-bottom: 1px solid var(--border); }
    .faq-q       { width: 100%; background: none; border: none; padding: 1.25rem 0; display: flex; align-items: center; justify-content: space-between; gap: 1rem; cursor: pointer; text-align: left; font-family: 'DM Sans', sans-serif; font-size: 0.9375rem; font-weight: 500; color: var(--text); transition: color 0.15s; }
    .faq-q:hover { color: var(--brand); }
    .faq-icon    { width: 20px; height: 20px; border: 1px solid var(--border-strong); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.7rem; color: var(--muted); transition: transform 0.25s, background 0.15s, border-color 0.15s; }
    .faq-item.open .faq-icon { transform: rotate(45deg); background: var(--brand); border-color: var(--brand); color: #fff; }
    .faq-a       { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; font-size: 0.875rem; color: var(--muted); line-height: 1.75; font-weight: 300; }
    .faq-item.open .faq-a { max-height: 200px; padding-bottom: 1.5rem; }

    /* ── FINAL CTA ── */
    .final-cta    { padding: 5rem 1.25rem; text-align: center; border-top: 1px solid var(--border); }
    .final-cta h2 { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.875rem, 6vw, 3.75rem); font-weight: 300; letter-spacing: -0.04em; color: var(--text); max-width: 600px; margin: 0 auto 1.25rem; line-height: 1.1; }
    .final-cta h2 strong { font-weight: 700; color: var(--brand); }
    .final-cta p  { font-size: 1rem; color: var(--muted); max-width: 420px; margin: 0 auto 2.5rem; font-weight: 300; line-height: 1.75; }
    .final-actions { display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--border); padding: 1.75rem 1.25rem; }
    .footer-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.75rem; }
    .footer-copy  { font-size: 0.8rem; color: var(--faint); }
    .footer-links { display: flex; gap: 1.25rem; }
    .footer-links a { font-size: 0.8rem; color: var(--faint); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--text); }

    /* ── SCROLL TO TOP ── */
    .scroll-top { position: fixed; bottom: 1.5rem; right: 1.5rem; width: 40px; height: 40px; background: var(--brand); color: #fff; border: 2px solid rgba(255,255,255,0.6); border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(5,64,96,0.25); opacity: 0; transform: translateY(10px); transition: opacity 0.25s, transform 0.25s, background 0.15s; pointer-events: none; z-index: 99; }
    .scroll-top.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
    .scroll-top:hover { background: var(--brand-mid); }

    .fade-up { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }

    /* hide mobile actions on desktop */
    @media (min-width: 769px) {
      .mobile-header-actions { display: none !important; }
      .mobile-menu { display: none !important; }
    }

    @media (max-width: 768px) {
      .mobile-header-actions .btn-ghost {
        font-size: 0.8125rem;
        padding: 0.4rem 0.75rem;
        border: 1px solid var(--border-strong);
        border-radius: 9999px;
        color: var(--text);
      }
    }
    /* ════════════════════════════════════
       RESPONSIVE — tablet ≤768px (hamburger)
    ════════════════════════════════════ */
    @media (max-width: 768px) {
      .desktop-nav   { display: none; }
      .hamburger     { display: flex; }
      .header-right  { display: none; }
      .mobile-header-actions { display: flex !important; }
    }

    /* ════════════════════════════════════
       RESPONSIVE — tablet ≤900px
    ════════════════════════════════════ */
    @media (max-width: 900px) {
      .desktop-nav { display: none; }
      .hamburger { display: flex; }
      /* hide desktop-only header items */
      .header-right .theme-toggle { display: none; }
      .header-right .btn-primary   { display: none; }
      .how-grid         { grid-template-columns: 1fr; gap: 3rem; }
      .how-visual       { position: static; }
      .providers-inner  { grid-template-columns: 1fr; gap: 3rem; }
      .hero-meta        { max-width: 480px; }
    }

    /* ════════════════════════════════════
       RESPONSIVE — mobile ≤480px
    ════════════════════════════════════ */
    @media (max-width: 480px) {
      /* Header */
      header { padding: 0 1rem; height: 56px; }
      .logo img { height: 32px; }

      /* Hero */
      .hero { padding: 4.5rem 1rem 3rem; }
      .hero-orb-1 { width: 260px; height: 260px; top: -80px; left: -80px; }
      .hero-orb-2 { width: 200px; height: 200px; bottom: -60px; right: -60px; }
      .hero-actions { flex-direction: column; }
      .hero-actions .btn-primary-lg,
      .hero-actions .btn-secondary-lg { width: 100%; justify-content: center; }
      .hero-meta { max-width: 100%; }

      /* Secciones */
      .how               { padding: 4rem 1rem; }
      .services-section  { padding: 4rem 1rem; }
      .testimonials-section { padding: 4rem 1rem; }
      .providers-section { padding: 4rem 1rem; }
      .faq-section       { padding: 4rem 1rem; }
      .final-cta         { padding: 4rem 1rem; }

      /* Services: 3 columnas en mobile */
      .services-grid { grid-template-columns: repeat(3, 1fr); gap: 0.5rem; }
      .service-chip  { padding: 1rem 0.5rem; }

      /* Testimonials: 1 columna */
      .testimonials-grid { grid-template-columns: 1fr; }

      /* Final CTA buttons */
      .final-actions { flex-direction: column; }
      .final-actions .btn-primary-lg,
      .final-actions .btn-secondary-lg { width: 100%; justify-content: center; }

      /* Footer */
      .footer-inner { flex-direction: column; align-items: flex-start; }
    }

    /* ════════════════════════════════════
       RESPONSIVE — 320px edge case
    ════════════════════════════════════ */
    @media (max-width: 360px) {
      .hero h1 { font-size: 1.875rem; }
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .btn-primary { padding: 0.5rem 0.875rem; font-size: 0.8125rem; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <header>
    <a href="/" class="logo">
      <img src="logo.png" alt="Aliados" />
    </a>

    <!-- Desktop nav -->
    <nav class="desktop-nav">
      <a href="#como-funciona">Cómo funciona</a>
      <a href="#servicios">Servicios</a>
      <a href="#proveedores">Para profesionales</a>
      <a href="#faq">FAQ</a>
    </nav>

    <!-- Desktop right -->
